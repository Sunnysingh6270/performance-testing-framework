{
  "compilerOptions": {
    "target": "es2020",
    "module": "es2020",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": [
      "k6"
    ],
    "allowImportingTsExtensions": true,
    "noEmit": true
  },
  "include": [
    "**/*.ts"
  ]
}
